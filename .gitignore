## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.Generated.vshost.exe
*.Generated.vshost.exe.config
*.Generated.vshost.exe.manifest

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
Logs/

# Visual Studio 2015/2017/2019/2022 cache and settings
.vs/
# Uncomment if you want to ignore the whole .vs folder
# .vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework Core migration report
*.migration_report.xml

# Git versioning
.git/

# Docker
.dockerignore

# Environment files
.env
.env.*
appsettings.Local.json

# Node.js / Web
node_modules/
wwwroot/lib/
dist/

# OS generated files
.DS_Store
Thumbs.db
